{{!
    @template block_ace_quests/block_content

    Block content template for the My Quests block.

    Context variables:
    * issitecontext - Whether we are on the site dashboard
    * quests - Array of quest card data (course mode)
    * hasquests - Whether there are quests (course mode)
    * xp - Total XP for the course (course mode)
    * level - Current level (course mode)
    * courses - Array of course objects with quests (site mode)
    * hascourses - Whether there are courses with quests (site mode)
    * totalxp - Total XP across all courses (site mode)
    * totalquests - Total active quests (site mode)
}}
<div class="block-ace-quests-content">

    {{! ===== SITE DASHBOARD MODE ===== }}
    {{#issitecontext}}
        {{#hascourses}}
            {{! Summary }}
            <div class="d-flex justify-content-between mb-3 small">
                <span class="badge bg-warning text-dark">{{totalxp}} XP</span>
                <span class="text-muted">{{totalquests}} {{#str}}activequests, local_aceengine{{/str}}</span>
            </div>

            {{! Course sections }}
            {{#courses}}
                <div class="mb-3">
                    <div class="d-flex align-items-center justify-content-between mb-2">
                        <a href="{{courseurl}}" class="fw-bold text-truncate small" title="{{coursename}}">
                            {{coursename}}
                        </a>
                        <span class="badge bg-info ms-1">Lv.{{level}}</span>
                    </div>
                    {{#quests}}
                        <div class="d-flex align-items-center justify-content-between py-1 border-bottom">
                            <div class="text-truncate me-2 small">
                                <span class="badge bg-secondary rounded-pill me-1 ace-quest-type-badge">{{questtypelabel}}</span>
                                {{#hasactivityurl}}
                                    <a href="{{activityurl}}" class="text-body">{{title}}</a>
                                {{/hasactivityurl}}
                                {{^hasactivityurl}}
                                    {{title}}
                                {{/hasactivityurl}}
                            </div>
                            <span class="badge bg-warning text-dark rounded-pill ace-quest-xp-badge">+{{xpreward}}</span>
                        </div>
                    {{/quests}}
                </div>
            {{/courses}}
        {{/hascourses}}

        {{^hascourses}}
            <p class="text-muted text-center small mb-0">
                {{#str}}noquests, block_ace_quests{{/str}}
            </p>
        {{/hascourses}}
    {{/issitecontext}}

    {{! ===== COURSE MODE ===== }}
    {{^issitecontext}}
        {{#hasquests}}
            {{! XP/Level summary }}
            <div class="d-flex justify-content-between mb-3 small">
                <span class="badge bg-warning text-dark">{{xp}} XP</span>
                <span class="badge bg-info">Lv.{{level}}</span>
            </div>

            {{! Quest list }}
            {{#quests}}
                <div class="d-flex align-items-center justify-content-between py-1 border-bottom">
                    <div class="text-truncate me-2 small">
                        <span class="badge bg-secondary rounded-pill me-1 ace-quest-type-badge">{{questtypelabel}}</span>
                        {{#hasactivityurl}}
                            <a href="{{activityurl}}" class="text-body">{{title}}</a>
                        {{/hasactivityurl}}
                        {{^hasactivityurl}}
                            {{title}}
                        {{/hasactivityurl}}
                    </div>
                    <span class="badge bg-warning text-dark rounded-pill ace-quest-xp-badge">+{{xpreward}}</span>
                </div>
            {{/quests}}
        {{/hasquests}}

        {{^hasquests}}
            <p class="text-muted text-center small mb-0">
                {{#str}}noquests, block_ace_quests{{/str}}
            </p>
        {{/hasquests}}
    {{/issitecontext}}

</div>
